# ── Supabase (bắt buộc) ─────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Admin (server-only) ──────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Danh sách email admin (phân cách bằng dấu phẩy, không có khoảng trắng)
ADMIN_EMAILS=luongvanquan93@gmail.com

# ── URL gốc (bắt buộc cho LINE OAuth) ───────────────────────────────────
# Local: http://localhost:3000   |   Production: https://chococfko.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────────────
# Bật tại: Supabase Dashboard → Authentication → Providers → Google
# Tạo credentials tại: https://console.cloud.google.com/apis/credentials
# (Không cần thêm vào đây — cấu hình trong Supabase dashboard là đủ)

# ── Facebook OAuth ───────────────────────────────────────────────────────
# Bật tại: Supabase Dashboard → Authentication → Providers → Facebook
# Tạo app tại: https://developers.facebook.com
# (Không cần thêm vào đây — cấu hình trong Supabase dashboard là đủ)

# ── LINE Login ───────────────────────────────────────────────────────────
# Tạo LINE Login channel tại: https://developers.line.biz/console/
# Thêm Callback URL trong LINE Console: {NEXT_PUBLIC_SITE_URL}/auth/line/callback
LINE_CHANNEL_ID=1234567890
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ảnh minh họa từ vựng (server-only) ──────────────────────────────────
# Đăng ký tại: https://www.pexels.com/api/
PEXELS_API_KEY=
# Đăng ký tại: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Provider ưu tiên: pexels | pixabay (mặc định: pexels)
IMAGE_PROVIDER=pexels

# ── OCR & dịch ảnh tiếng Nhật (server-only) ─────────────────────────────
# Dùng cho /japanese/image-translate (OCR + dịch). Nếu để trống, trang vẫn
# hoạt động nhưng hiển thị thông báo "chưa cấu hình" thay vì kết quả.
#
# Google Cloud: bật "Cloud Vision API" và "Cloud Translation API", tạo API key
# (giới hạn theo 2 API đó). Một key dùng chung cho cả hai:
GOOGLE_CLOUD_API_KEY=
# Hoặc tách riêng nếu muốn (sẽ ưu tiên các biến chuyên dụng này):
GOOGLE_VISION_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
# Chọn nhà cung cấp (mặc định: google). Đặt "none" để tắt tính năng.
OCR_PROVIDER=google
TRANSLATE_PROVIDER=google

# ── Nhận diện chữ Kanji viết tay ────────────────────────────────────────
# Mặc định dùng Google Input Tools (miễn phí, không cần API key) nên tính
# năng "Vẽ Kanji" hoạt động ngay. Đặt "none" để tắt.
HANDWRITING_PROVIDER=google_inputtools

# ── Bản đồ: nhà cung cấp & cờ tính năng (Phase 3) ───────────────────────
# MẶC ĐỊNH GIỮ NGUYÊN LEAFLET/OPENSTREETMAP. Mọi giá trị thiếu hoặc không hợp lệ
# đều tự động fallback về Leaflet — bản đồ production không bao giờ vỡ.
#
# Nhà cung cấp bản đồ: leaflet | google (giá trị lạ → leaflet)
NEXT_PUBLIC_MAP_PROVIDER=leaflet
# Bật trang nền tảng Google (route /map/lab). false = không hiển thị lab.
NEXT_PUBLIC_MAP_V2_ENABLED=false
# Công tắc tổng: có được PHÉP tải Google Maps JS hay không.
NEXT_PUBLIC_GOOGLE_MAPS_ENABLED=false
# Xem trước POI ngoài của Google (chỉ có tác dụng khi Google đang hoạt động).
NEXT_PUBLIC_GOOGLE_EXTERNAL_POI_ENABLED=false
# Xem trước chỉ đường (Routes API) — chỉ có tác dụng khi Google đang hoạt động.
NEXT_PUBLIC_GOOGLE_ROUTE_PREVIEW_ENABLED=false
# Trong giai đoạn thử nghiệm: chỉ cho admin nội bộ thấy V2/Google. Mặc định true.
NEXT_PUBLIC_MAP_INTERNAL_ONLY=true
# Bật ô tìm địa điểm Google trong trình sửa Admin (Phase 5). Tắt → admin nhập toạ
# độ thủ công như cũ. Cần thêm GOOGLE_MAPS_ENABLED=true + browser key bên dưới.
NEXT_PUBLIC_ADMIN_PLACE_SEARCH_ENABLED=false
#
# Khoá Maps JS dành cho TRÌNH DUYỆT (NEXT_PUBLIC = lộ ra client — BẮT BUỘC hạn chế
# theo HTTP referrer + theo API trong Google Cloud Console). KHÁC với
# GOOGLE_CLOUD_API_KEY (server-only, cho OCR/dịch) ở trên — KHÔNG dùng chung.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Map ID (bắt buộc cho Advanced Markers). Để trống → dùng DEMO_MAP_ID khi dev.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
#
# Khoá Routes API dành cho SERVER (server-only — KHÔNG phải NEXT_PUBLIC, không lộ
# ra client). Dùng cho /api/maps/route (xem trước chỉ đường Phase 8). Giới hạn key
# theo Routes API trong Cloud Console. Thiếu key → xem trước tuyến trả "unavailable"
# (nút "Mở Google Maps" vẫn hoạt động). KHÁC với GOOGLE_CLOUD_API_KEY (OCR/dịch).
GOOGLE_MAPS_SERVER_KEY=

# ── Tự động làm giàu thuộc tính địa điểm từ Google Places API (New) ──────
# Dùng cho job enrichment (scripts/enrich-places.mjs + cron /api/cron/enrich-places
# + hook khi tạo địa điểm). Server-only — KHÔNG đặt NEXT_PUBLIC, không lộ client.
# Bật "Places API (New)" trong Google Cloud, tạo key (giới hạn theo Places API +
# IP/referrer). Thiếu key → mọi đường enrichment NO-OP an toàn (app/build không vỡ).
# Nếu để trống, hệ thống sẽ thử dùng GOOGLE_MAPS_SERVER_KEY ở trên (nếu key đó cũng
# đã bật Places API New). KHUYẾN NGHỊ tạo key riêng cho Places API.
GOOGLE_PLACES_API_KEY=

# ── Poker feature flags (server-only; rollout controls) ──────────────────
# Poker ships DARK. Every flag defaults OFF → a fresh deploy shows poker to
# NOBODY but admins (admin-only production visibility). Admins bypass the public
# gates so they can validate on prod before any flag is flipped. Flip on-value =
# 1 / true / on / yes (anything else = off). Do NOT NEXT_PUBLIC these — gating is
# resolved server-side (lib/games/poker/flags.ts + app/games/poker/access.ts).
#
# Suggested rollout order: ENABLED → PUBLIC_LOBBY + CREATE_TABLE (limited beta) →
# PRIVATE_TABLE / SPECTATOR as desired. BOT + TOURNAMENT are out of scope for this
# release and stay hard-off in code even if set true here.
POKER_ENABLED=false
POKER_CREATE_TABLE_ENABLED=false
POKER_PUBLIC_LOBBY_ENABLED=false
POKER_PRIVATE_TABLE_ENABLED=false
POKER_SPECTATOR_ENABLED=false
POKER_BOT_ENABLED=false
POKER_TOURNAMENT_ENABLED=false

# ── Poker integrity (anti-collusion) — server-only ───────────────────────
# HMAC salt used to hash device/network identifiers before they are stored or
# correlated (lib/games/poker/integrity/privacy.ts). MUST be a long random
# secret, server-only, and NEVER NEXT_PUBLIC. Rotating it invalidates existing
# identity tokens (by design — tokens are not portable across salts). Absent =
# identifier correlation is simply disabled (behavioural signals still work).
POKER_INTEGRITY_ID_SALT=

# ── Đổi tên file này thành .env.local và điền giá trị thật ──────────────
