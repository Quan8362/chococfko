# ════════════════════════════════════════════════════════════════════════════════════════
# ISOLATED POKER BOT PLAYTEST — environment template (NON-SECRET)
# ════════════════════════════════════════════════════════════════════════════════════════
# Copy to `.env.playtest.local` for LOCAL, or paste each value as a Vercel *Preview* variable
# for INTERNAL STAGING. NEVER put production values here. NEVER apply this to Vercel Production.
# `.env.playtest.local` is git-ignored via the `.env*.local` rule — do not commit real keys.
#
# Enforced by: lib/playtest/env-guard.ts + scripts/poker-playtest/health-check.mjs
# The app REFUSES to run the playtest if any value below points at production (fail-closed).
# ════════════════════════════════════════════════════════════════════════════════════════

# ── Environment identity (drives the banner + the fail-closed guard) ─────────────────────
# Must be exactly "local" or "staging". Anything else → guard refuses, banner shows a warning.
NEXT_PUBLIC_APP_ENV=staging

# ── Isolated Supabase project (MUST be different from production) ─────────────────────────
# Create a SEPARATE Supabase project (recommended) or a Supabase branch, then paste ITS values.
# The guard refuses to boot if this host equals the production Supabase host.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_ISOLATED_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ISOLATED_ANON_KEY
# Server-only. NEVER prefix with NEXT_PUBLIC. Used only by trusted server actions + scripts.
SUPABASE_SERVICE_ROLE_KEY=YOUR_ISOLATED_SERVICE_ROLE_KEY
# Optional override of the production deny-list host (public identifier, not a secret):
# PLAYTEST_PROD_SUPABASE_HOST=kjfnqbzfhymhfodmgyow.supabase.co

# ── Site URL (preview or localhost) — NOT the production domain ──────────────────────────
# Staging (Vercel preview): https://<your-preview>.vercel.app   |   Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://YOUR-PREVIEW.vercel.app

# ── Internal tester allowlist (server-enforced; exactly the two authorized accounts) ─────
# ADMIN_EMAILS and POKER_ALPHA_TESTERS are BOTH limited to the two testers so no other
# account — admin or otherwise — can reach the playtest.
ADMIN_EMAILS=tester-a@example.com,tester-b@example.com
POKER_ALPHA_MODE=1
POKER_ALPHA_TESTERS=tester-a@example.com,tester-b@example.com

# Two-account Playwright suite reads the tester identities from here (never hardcoded in the repo).
PLAYTEST_TESTER_A_EMAIL=tester-a@example.com
PLAYTEST_TESTER_B_EMAIL=tester-b@example.com

# ── Practice-bot playtest: the ONLY poker capability that is ON ──────────────────────────
POKER_PRACTICE_BOTS_ENABLED=1

# ── Everything real-money / public / tournament stays OFF (also fail-closed in code) ─────
POKER_ENABLED=0
POKER_CREATE_TABLE_ENABLED=0
POKER_PUBLIC_LOBBY_ENABLED=0
POKER_PRIVATE_TABLE_ENABLED=0
POKER_SPECTATOR_ENABLED=0
POKER_BOT_ENABLED=0            # live cash-game bots — hard-off in code regardless of this value
POKER_TOURNAMENT_ENABLED=0     # tournaments — hard-off in code regardless of this value
POKER_CLOSED_BETA_ENABLED=0
POKER_ACHIEVEMENTS_ENABLED=0
POKER_MISSIONS_ENABLED=0
POKER_FRIEND_INVITES_ENABLED=0
POKER_QUICK_MESSAGES_ENABLED=0
POKER_HAND_SHARING_ENABLED=0
POKER_INTEGRITY_ID_SALT=
