/node_modules
/.next
/out
.env*.local
.DS_Store
# Windows reserved-name junk file (breaks `git add -A`)
/nul
*.tsbuildinfo
next-env.d.ts

.vercel

# JMdict raw source files (too large for git)
data/source/JMdict_e
data/source/JMdict_e.gz

# Python bytecode cache
__pycache__/
*.pyc

# Playwright test artifacts (generated; do not commit)
/test-results/
/playwright-report/
/e2e/screenshots/

# TLMN training/eval reports (generated artifacts; do not commit)
/lib/games/tlmn/sim/reports/

# TLMN E2E auth states (contain session tokens) + run artifacts — never commit
/e2e/tlmn/.auth/
/e2e/tlmn/.artifacts/

# FUSE mount artifacts (appear when an open file is deleted)
.fuse_hidden*
