{
  "name": "chococfko",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:explore": "next lint --dir lib --dir app/places --dir app/events --dir app/collections --dir app/plans --dir app/lists --dir app/api/cron --dir app/api/health --dir app/admin/places",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "i18n:check": "node scripts/check-i18n-parity.mjs",
    "test": "node --test \"lib/**/*.test.ts\"",
    "tlmn:scenarios": "node lib/games/tlmn/sim/cli.ts scenarios",
    "tlmn:sim": "node lib/games/tlmn/sim/cli.ts sim",
    "tlmn:eval": "node lib/games/tlmn/sim/cli.ts eval",
    "tlmn:train": "node lib/games/tlmn/sim/cli.ts train",
    "poker:economy:list": "node lib/games/poker/sim/cli.ts list",
    "poker:economy:run": "node lib/games/poker/sim/cli.ts run",
    "poker:economy:sweep": "node lib/games/poker/sim/cli.ts sweep",
    "test:tlmn:unit": "node --test \"lib/games/tlmn/**/*.test.ts\"",
    "test:tlmn:qa": "node --test \"lib/games/tlmn/qa-acceptance.test.ts\"",
    "qa:tlmn": "npm run test:tlmn:unit && npm run test:tlmn:qa",
    "test:e2e:tlmn": "playwright test --config e2e/tlmn/tlmn.config.ts --project realtime --project responsive",
    "test:e2e:tlmn:full": "playwright test --config e2e/tlmn/tlmn.config.ts",
    "test:e2e:tlmn:report": "playwright show-report e2e/tlmn/.artifacts/html",
    "test:e2e:tlmn:teardown": "node e2e/tlmn/teardown.mjs",
    "test:e2e:poker": "playwright test --config e2e/poker/poker.config.ts --project smoke --project responsive",
    "test:e2e:poker:full": "playwright test --config e2e/poker/poker.config.ts",
    "test:e2e:poker:report": "playwright show-report e2e/poker/.artifacts/html"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tiptap/extension-highlight": "^3.24.0",
    "@tiptap/extension-image": "^3.24.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-table": "^3.24.0",
    "@tiptap/extension-text-align": "^3.24.0",
    "@tiptap/extension-text-style": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "framer-motion": "^12.42.0",
    "hanzi-writer": "^3.7.3",
    "jimp": "^0.22.12",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "^14.2.35",
    "next-intl": "^4.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
